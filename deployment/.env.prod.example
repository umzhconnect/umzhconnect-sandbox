# =============================================================================
# Production environment — copy to .env at the repo root on the VPS and fill in
# all values marked <CHANGE_ME>.
#
# Do NOT commit the filled-in .env to version control.
# =============================================================================

# --- PostgreSQL (bundled container — default) ---
POSTGRES_USER=umzh
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_DB=hapi_fhir

# --- Managed PostgreSQL (only when using deployment/docker-compose.managed-db.yml) ---
# Provision the two databases (or two schemas) and their users via the provider
# console first; the bundled init script does not run in this mode. See the
# "Using a managed database service" section in deployment.md.
#DB_HOST=<your-managed-db-host>
#DB_PORT=5432
#DB_SSLMODE=require
#KEYCLOAK_DB_NAME=keycloak
#KEYCLOAK_DB_USER=<CHANGE_ME>
#KEYCLOAK_DB_PASSWORD=<CHANGE_ME>
#HAPI_DB_NAME=hapi_fhir
#HAPI_DB_USER=<CHANGE_ME>
#HAPI_DB_PASSWORD=<CHANGE_ME>

# --- HAPI FHIR ---
HAPI_FHIR_PORT=8090
HAPI_FHIR_BASE_URL=http://hapi-fhir:8080

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<CHANGE_ME>
KEYCLOAK_PORT=8180
PLACER_USER_PASSWORD=<CHANGE_ME>
FULFILLER_USER_PASSWORD=<CHANGE_ME>
ADMIN_USER_PASSWORD=<CHANGE_ME>
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=umzh-connect

# --- Keycloak Clients (Level 1 - shared secret) ---
PLACER_CLIENT_ID=placer-client
PLACER_CLIENT_SECRET=<CHANGE_ME>
FULFILLER_CLIENT_ID=fulfiller-client
FULFILLER_CLIENT_SECRET=<CHANGE_ME>

# --- Keycloak Clients (Level 2 - private_key_jwt) ---
PLACER_L2_CLIENT_ID=placer-client-l2
FULFILLER_L2_CLIENT_ID=fulfiller-client-l2
# JWKS endpoints Keycloak fetches to verify L2 private_key_jwt assertions.
# In production each party exposes its JWKS at its public external subdomain;
# Keycloak fetches over HTTPS (out to Caddy and back to the external gateway).
PLACER_JWKS_URL=https://placer.sandbox.umzh-connect.ch/jwks.json
FULFILLER_JWKS_URL=https://fulfiller.sandbox.umzh-connect.ch/jwks.json

# --- APISIX gateway ports (unchanged — Caddy proxies to these) ---
APISIX_PLACER_PORT=8080
APISIX_PLACER_EXTERNAL_PORT=8081
APISIX_FULFILLER_PORT=8082
APISIX_FULFILLER_EXTERNAL_PORT=8083

# --- OPA ---
OPA_PLACER_PORT=8181
OPA_FULFILLER_PORT=8182

# --- Registry ---
REGISTRY_PORT=8084
# Canonical public registry base URL — the single source of truth. The web-app
# (VITE_REGISTRY_URL), admin-api/seed (REGISTRY_EXTERNAL_URL), nginx-proxy, and
# each M2M client's organization_reference claim all derive from this value in
# docker-compose. It MUST match the URL in stored consent actors and
# Task.requester so OPA consent matching and Task requester-inject work.
REGISTRY_PUBLIC_URL=https://registry.sandbox.umzh-connect.ch

# --- Key custodians ---
KEY_CUSTODIAN_PLACER_PORT=8087
KEY_CUSTODIAN_FULFILLER_PORT=8089

# --- Admin API (merged reseed + onboarding) ---
# Served publicly at admin.sandbox.umzh-connect.ch (Caddy → localhost:9000).
# ONBOARDING_CLIENT_SECRET must match the "onboarding-client" secret in
# services/keycloak/realm-export.json.
ADMIN_API_PORT=9000
ONBOARDING_CLIENT_SECRET=<CHANGE_ME>
VITE_ADMIN_API_URL=https://admin.sandbox.umzh-connect.ch

# --- Web app ---
WEB_APP_PORT=3000
# Public origin of the SPA — resolved into Keycloak realm-export.json
# (webOrigins / redirectUris / rootUrl) at import time.
WEB_APP_PUBLIC_URL=https://sandbox.umzh-connect.ch
VITE_API_BASE_URL=
VITE_KEYCLOAK_URL=https://auth.sandbox.umzh-connect.ch
VITE_KEYCLOAK_REALM=umzh-connect
VITE_KEYCLOAK_CLIENT_ID=web-app
VITE_PLACER_URL=https://placer-int.sandbox.umzh-connect.ch
VITE_PLACER_EXTERNAL_URL=https://placer.sandbox.umzh-connect.ch
VITE_FULFILLER_URL=https://fulfiller-int.sandbox.umzh-connect.ch
VITE_FULFILLER_EXTERNAL_URL=https://fulfiller.sandbox.umzh-connect.ch
