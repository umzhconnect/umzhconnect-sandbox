{
  "$schema": "https://www.krakend.io/schema/krakend.json",
  "version": 3,
  "name": "UMZH Connect — HospitalF (Fulfiller) External API Gateway",
  "port": 8080,
  "timeout": "30s",
  "cache_ttl": "0s",
  "output_encoding": "no-op",
  "extra_config": {
    "router": {
      "return_error_msg": true
    },
    "security/cors": {
      "allow_origins": ["http://localhost:3000", "*"],
      "allow_methods": ["GET", "POST", "PUT", "OPTIONS"],
      "allow_headers": ["Authorization", "Content-Type", "Accept"],
      "expose_headers": ["Content-Length", "Content-Type"],
      "max_age": "12h",
      "allow_credentials": true
    }
  },
  "endpoints": [

    {
      "comment": "=== External FHIR API — Placer posts Task into Fulfiller partition ===",
      "endpoint": "/fhir/Task",
      "method": "POST",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/fulfiller/Task",
          "host": ["http://nginx-proxy:83"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["party_id", "x-party-id"],
            ["smart_scopes", "x-smart-scopes"],
            ["scope", "x-scope"]
          ]
        }
      }
    },
    {
      "comment": "=== External FHIR API — Placer updates Task status in Fulfiller partition ===",
      "endpoint": "/fhir/Task/{id}",
      "method": "PUT",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/fulfiller/Task/{id}",
          "host": ["http://nginx-proxy:83"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true
        }
      }
    },
    {
      "comment": "=== External FHIR API — Placer reads Fulfiller resources (generic) ===",
      "endpoint": "/fhir/{resource}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "input_query_strings": ["*"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/fulfiller/{resource}",
          "host": ["http://nginx-proxy:83"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["party_id", "x-party-id"],
            ["smart_scopes", "x-smart-scopes"],
            ["scope", "x-scope"],
            ["consent_id", "x-consent-id"]
          ]
        }
      }
    },
    {
      "endpoint": "/fhir/{resource}/{id}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/fulfiller/{resource}/{id}",
          "host": ["http://nginx-proxy:83"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["party_id", "x-party-id"],
            ["smart_scopes", "x-smart-scopes"],
            ["scope", "x-scope"],
            ["consent_id", "x-consent-id"]
          ]
        }
      }
    }

  ]
}
