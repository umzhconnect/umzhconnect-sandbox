{
  "$schema": "https://www.krakend.io/schema/krakend.json",
  "version": 3,
  "name": "UMZH Connect — HospitalF (Fulfiller) API Gateway",
  "port": 8080,
  "timeout": "30s",
  "cache_ttl": "0s",
  "output_encoding": "no-op",
  "extra_config": {
    "router": {
      "return_error_msg": true
    },
    "security/cors": {
      "allow_origins": ["http://localhost:3000", "*"],
      "allow_methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
      "allow_headers": ["Authorization", "Content-Type", "Accept", "X-Tenant", "X-Consent-Id"],
      "expose_headers": ["Content-Length", "Content-Type"],
      "max_age": "12h",
      "allow_credentials": true
    }
  },
  "endpoints": [

    {
      "comment": "=== FHIR Metadata (no auth) ===",
      "endpoint": "/fhir/metadata",
      "method": "GET",
      "input_headers": ["Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/fulfiller/metadata",
          "host": ["http://nginx-proxy:82"],
          "encoding": "no-op"
        }
      ]
    },

    {
      "comment": "=== CATEGORY 1: Internal FHIR API — Fulfiller reads own partition ===",
      "endpoint": "/fhir/{resource}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "input_query_strings": ["*"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/fulfiller/{resource}",
          "host": ["http://nginx-proxy:82"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true
        }
      }
    },
    {
      "endpoint": "/fhir/{resource}/{id}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/fulfiller/{resource}/{id}",
          "host": ["http://nginx-proxy:82"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true
        }
      }
    },
    {
      "endpoint": "/fhir/{resource}",
      "method": "POST",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/fulfiller/{resource}",
          "host": ["http://nginx-proxy:82"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true
        }
      }
    },
    {
      "endpoint": "/fhir/{resource}/{id}",
      "method": "PUT",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/fulfiller/{resource}/{id}",
          "host": ["http://nginx-proxy:82"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true
        }
      }
    },

    {
      "comment": "=== CATEGORY 3: Proxy API — Fulfiller proxies Placer resources for web-app navigation (consent-gated) ===",
      "comment2": "Routes via nginx-proxy:85 which forwards to krakend-placer-external (JWT + consent validated there) and rewrites localhost:8081/fhir/ -> localhost:8082/proxy/fhir/ in the response body.",
      "endpoint": "/proxy/fhir/{resource}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept", "X-Consent-Id"],
      "input_query_strings": ["*"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/{resource}",
          "host": ["http://nginx-proxy:85"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["party_id", "x-party-id"],
            ["smart_scopes", "x-smart-scopes"],
            ["tenant", "x-tenant"],
            ["scope", "x-scope"]
          ]
        }
      }
    },
    {
      "endpoint": "/proxy/fhir/{resource}/{id}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept", "X-Consent-Id"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/{resource}/{id}",
          "host": ["http://nginx-proxy:85"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["party_id", "x-party-id"],
            ["smart_scopes", "x-smart-scopes"],
            ["tenant", "x-tenant"],
            ["scope", "x-scope"]
          ]
        }
      }
    },

    {
      "comment": "=== CATEGORY 3: Scoped Token — Fulfiller exchanges X-Consent-Id for a service-account JWT that carries consent:<id> in scope ===",
      "comment2": "Uses fulfiller-client M2M credentials (client_credentials grant). Lua pre-script constructs the Keycloak token request body dynamically from the X-Consent-Id header. The resulting JWT contains consent_id claim + scope=consent:<id> which the partner external gateway propagates to OPA.",
      "endpoint": "/api/actions/scoped-token",
      "method": "POST",
      "input_headers": ["Authorization", "X-Consent-Id"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/realms/umzh-connect/protocol/openid-connect/token",
          "host": ["http://keycloak:8080"],
          "encoding": "no-op",
          "method": "POST",
          "extra_config": {
            "modifier/lua-backend": {
              "sources": [],
              "pre": "local req = request.load(); local consent_id = req:headers('X-Consent-Id') or ''; local body = 'grant_type=client_credentials&client_id=fulfiller-client&client_secret=fulfiller-secret-2025&scope=consent:' .. consent_id; req:set_body(body); req:set_header('Content-Type', 'application/x-www-form-urlencoded');"
            }
          }
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true
        }
      }
    },

    {
      "comment": "=== CATEGORY 4: Actions API — Create task at partner's external endpoint (Placer) ===",
      "endpoint": "/api/actions/create-task",
      "method": "POST",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/Task",
          "host": ["http://krakend-placer-external:8080"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["party_id", "x-party-id"],
            ["smart_scopes", "x-smart-scopes"],
            ["scope", "x-scope"]
          ]
        }
      }
    },

    {
      "comment": "=== CATEGORY 4: Actions API — Fetch all tasks (local fulfiller + remote placer external) ===",
      "comment2": "Remote backend routes through nginx-proxy:85 (not directly to krakend-placer-external) so the sub_filter rewriting of placer self-links (localhost:8081/fhir/ -> localhost:8082/proxy/fhir/) is applied before KrakenD merges the two responses.",
      "endpoint": "/api/actions/all-tasks",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "input_query_strings": ["*"],
      "output_encoding": "json",
      "backend": [
        {
          "url_pattern": "/fhir/fulfiller/Task",
          "host": ["http://nginx-proxy:82"],
          "encoding": "json",
          "group": "local"
        },
        {
          "url_pattern": "/fhir/Task",
          "host": ["http://nginx-proxy:85"],
          "encoding": "json",
          "group": "remote"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["party_id", "x-party-id"],
            ["smart_scopes", "x-smart-scopes"],
            ["scope", "x-scope"]
          ]
        }
      }
    },

    {
      "comment": "=== OPA Policy Check (routes to Fulfiller OPA instance) ===",
      "endpoint": "/api/policy/check",
      "method": "POST",
      "input_headers": ["Authorization", "Content-Type"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/v1/data/umzh/authz/allow",
          "host": ["http://opa-fulfiller:8181"],
          "encoding": "no-op"
        }
      ]
    }

  ]
}
