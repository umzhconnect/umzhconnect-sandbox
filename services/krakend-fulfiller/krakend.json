{
  "$schema": "https://www.krakend.io/schema/krakend.json",
  "version": 3,
  "name": "UMZH Connect — HospitalF (Fulfiller) API Gateway",
  "port": 8080,
  "timeout": "30s",
  "cache_ttl": "0s",
  "output_encoding": "no-op",
  "extra_config": {
    "router": {
      "return_error_msg": true
    },
    "security/cors": {
      "allow_origins": ["http://localhost:3000", "*"],
      "allow_methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
      "allow_headers": ["Authorization", "Content-Type", "Accept", "X-Tenant", "X-Consent-Id"],
      "expose_headers": ["Content-Length", "Content-Type"],
      "max_age": "12h",
      "allow_credentials": true
    }
  },
  "endpoints": [

    {
      "comment": "=== FHIR Metadata (no auth) ===",
      "endpoint": "/fhir/metadata",
      "method": "GET",
      "input_headers": ["Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/fulfiller/metadata",
          "host": ["http://nginx-proxy:82"],
          "encoding": "no-op"
        }
      ]
    },

    {
      "comment": "=== CATEGORY 1: Internal FHIR API — Fulfiller reads own partition ===",
      "endpoint": "/fhir/{resource}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "input_query_strings": ["*"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/fulfiller/{resource}",
          "host": ["http://nginx-proxy:82"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true
        }
      }
    },
    {
      "endpoint": "/fhir/{resource}/{id}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/fulfiller/{resource}/{id}",
          "host": ["http://nginx-proxy:82"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true
        }
      }
    },
    {
      "endpoint": "/fhir/{resource}",
      "method": "POST",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/fulfiller/{resource}",
          "host": ["http://nginx-proxy:82"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true
        }
      }
    },
    {
      "endpoint": "/fhir/{resource}/{id}",
      "method": "PUT",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/fulfiller/{resource}/{id}",
          "host": ["http://nginx-proxy:82"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true
        }
      }
    },

    {
      "comment": "=== CATEGORY 3: Proxy API — Fulfiller proxies Placer resources with inline token exchange ===",
      "comment2": "Sequential proxy: Backend 0 obtains a consent-scoped M2M token from Keycloak via client_credentials, Backend 1 forwards the FHIR request to the partner external gateway using the M2M token. Lua post-script strips the token from the merged response.",
      "endpoint": "/proxy/fhir/{resource}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept", "X-Consent-Id"],
      "input_query_strings": ["*"],
      "output_encoding": "json",
      "backend": [
        {
          "comment": "Backend 0: Obtain consent-scoped M2M token from Keycloak",
          "url_pattern": "/realms/umzh-connect/protocol/openid-connect/token",
          "host": ["http://keycloak:8080"],
          "encoding": "json",
          "method": "POST",
          "group": "token_exchange",
          "extra_config": {
            "modifier/lua-backend": {
              "sources": ["lua/scoped_token.lua"],
              "pre": "pre_backend(request)"
            }
          }
        },
        {
          "comment": "Backend 1: Forward FHIR request to partner external gateway with M2M token",
          "url_pattern": "/fhir/{resource}",
          "host": ["http://krakend-placer-external:8080"],
          "encoding": "json",
          "extra_config": {
            "modifier/lua-backend": {
              "sources": ["lua/proxy_inject_token.lua"],
              "pre": "inject_token(request)"
            }
          }
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["party_id", "x-party-id"],
            ["smart_scopes", "x-smart-scopes"],
            ["tenant", "x-tenant"],
            ["scope", "x-scope"]
          ]
        },
        "proxy": {
          "sequential": true
        },
        "modifier/lua-proxy": {
          "sources": ["lua/proxy_response.lua"],
          "allow_open_libs": true,
          "post": "post_proxy(response)"
        }
      }
    },
    {
      "comment": "=== CATEGORY 3: Proxy API — Fulfiller proxies single Placer resource with inline token exchange ===",
      "endpoint": "/proxy/fhir/{resource}/{id}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept", "X-Consent-Id"],
      "output_encoding": "json",
      "backend": [
        {
          "comment": "Backend 0: Obtain consent-scoped M2M token from Keycloak",
          "url_pattern": "/realms/umzh-connect/protocol/openid-connect/token",
          "host": ["http://keycloak:8080"],
          "encoding": "json",
          "method": "POST",
          "group": "token_exchange",
          "extra_config": {
            "modifier/lua-backend": {
              "sources": ["lua/scoped_token.lua"],
              "pre": "pre_backend(request)"
            }
          }
        },
        {
          "comment": "Backend 1: Forward FHIR request to partner external gateway with M2M token",
          "url_pattern": "/fhir/{resource}/{id}",
          "host": ["http://krakend-placer-external:8080"],
          "encoding": "json",
          "extra_config": {
            "modifier/lua-backend": {
              "sources": ["lua/proxy_inject_token.lua"],
              "pre": "inject_token(request)"
            }
          }
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["party_id", "x-party-id"],
            ["smart_scopes", "x-smart-scopes"],
            ["tenant", "x-tenant"],
            ["scope", "x-scope"]
          ]
        },
        "proxy": {
          "sequential": true
        },
        "modifier/lua-proxy": {
          "sources": ["lua/proxy_response.lua"],
          "allow_open_libs": true,
          "post": "post_proxy(response)"
        }
      }
    },

    {
      "comment": "=== CATEGORY 4: Actions API — Create task at partner's external endpoint (Placer) ===",
      "endpoint": "/api/actions/create-task",
      "method": "POST",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/Task",
          "host": ["http://krakend-placer-external:8080"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["party_id", "x-party-id"],
            ["smart_scopes", "x-smart-scopes"],
            ["scope", "x-scope"]
          ]
        }
      }
    },

    {
      "comment": "=== CATEGORY 4: Actions API — Fetch all tasks (local fulfiller + remote placer external) ===",
      "comment2": "Remote backend routes directly to krakend-placer-external with Lua post-processing for URL rewriting (localhost:8081/fhir/ -> localhost:8082/proxy/fhir/).",
      "endpoint": "/api/actions/all-tasks",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "input_query_strings": ["*"],
      "output_encoding": "json",
      "backend": [
        {
          "url_pattern": "/fhir/fulfiller/Task",
          "host": ["http://nginx-proxy:82"],
          "encoding": "json",
          "group": "local"
        },
        {
          "url_pattern": "/fhir/Task",
          "host": ["http://krakend-placer-external:8080"],
          "encoding": "json",
          "group": "remote"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["party_id", "x-party-id"],
            ["smart_scopes", "x-smart-scopes"],
            ["scope", "x-scope"]
          ]
        },
        "modifier/lua-proxy": {
          "sources": ["lua/proxy_response.lua"],
          "allow_open_libs": true,
          "post": "post_proxy(response)"
        }
      }
    },

    {
      "comment": "=== OPA Policy Check (routes to Fulfiller OPA instance) ===",
      "endpoint": "/api/policy/check",
      "method": "POST",
      "input_headers": ["Authorization", "Content-Type"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/v1/data/umzh/authz/allow",
          "host": ["http://opa-fulfiller:8181"],
          "encoding": "no-op"
        }
      ]
    }

  ]
}
