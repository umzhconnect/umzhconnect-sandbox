{
  "$schema": "https://www.krakend.io/schema/krakend.json",
  "version": 3,
  "name": "UMZH Connect — {{ env "GATEWAY_NAME" }} API Gateway",
  "port": 8080,
  "timeout": "30s",
  "cache_ttl": "0s",
  "output_encoding": "no-op",
  "extra_config": {
    "router": {
      "return_error_msg": true
    },
    "security/cors": {
      "allow_origins": ["http://localhost:3000", "*"],
      "allow_methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
      "allow_headers": ["Authorization", "Content-Type", "Accept", "X-Tenant", "X-Consent-Id"],
      "expose_headers": ["Content-Length", "Content-Type"],
      "max_age": "12h",
      "allow_credentials": true
    }
  },
  "endpoints": [
    {
      "comment": "=== FHIR Metadata (no auth) ===",
      "endpoint": "/fhir/metadata",
      "method": "GET",
      "input_headers": ["Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/{{ env "PARTY" }}/metadata",
          "host": ["http://nginx-proxy:{{ env "NGINX_PORT" }}"],
          "encoding": "no-op"
        }
      ]
    },
    {
      "comment": "=== CATEGORY 1: Internal FHIR API — reads own partition ===",
      "endpoint": "/fhir/{resource}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "input_query_strings": ["*"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/{{ env "PARTY" }}/{resource}",
          "host": ["http://nginx-proxy:{{ env "NGINX_PORT" }}"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "{{ env "KEYCLOAK_URL" }}/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "roles_key": "realm_roles",
          "roles": ["{{ env "PARTY" }}"]
        },
        "modifier/lua-proxy": {
          "sources": ["lua/proxy_rewrite.lua"],
          "allow_open_libs": true,
          "post": "rewriteUrls()"
        }
      }
    },
    {
      "endpoint": "/fhir/{resource}/{id}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/{{ env "PARTY" }}/{resource}/{id}",
          "host": ["http://nginx-proxy:{{ env "NGINX_PORT" }}"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "{{ env "KEYCLOAK_URL" }}/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "roles_key": "realm_roles",
          "roles": ["{{ env "PARTY" }}"]
        },
        "modifier/lua-proxy": {
          "sources": ["lua/proxy_rewrite.lua"],
          "allow_open_libs": true,
          "post": "rewriteUrls()"
        }
      }
    },
    {
      "endpoint": "/fhir/{resource}",
      "method": "POST",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/{{ env "PARTY" }}/{resource}",
          "host": ["http://nginx-proxy:{{ env "NGINX_PORT" }}"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "{{ env "KEYCLOAK_URL" }}/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "roles_key": "realm_roles",
          "roles": ["{{ env "PARTY" }}"]
        },
        "modifier/lua-proxy": {
          "sources": ["lua/proxy_rewrite.lua"],
          "allow_open_libs": true,
          "post": "rewriteUrls()"
        }
      }
    },
    {
      "endpoint": "/fhir/{resource}/{id}",
      "method": "PUT",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/{{ env "PARTY" }}/{resource}/{id}",
          "host": ["http://nginx-proxy:{{ env "NGINX_PORT" }}"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "{{ env "KEYCLOAK_URL" }}/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "roles_key": "realm_roles",
          "roles": ["{{ env "PARTY" }}"]
        },
        "modifier/lua-proxy": {
          "sources": ["lua/proxy_rewrite.lua"],
          "allow_open_libs": true,
          "post": "rewriteUrls()"
        }
      }
    },
    {
      "comment": "=== CATEGORY 3: Proxy API — proxies partner resources with inline token exchange ===",
      "comment2": "Sequential proxy: Backend 0 obtains a consent-scoped M2M token from Keycloak via client_credentials, Backend 1 forwards the FHIR request to the partner external gateway using the M2M token. Lua post-script strips the token from the merged response.",
      "endpoint": "/proxy/{party}/fhir/{resource}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept", "X-Consent-Id"],
      "input_query_strings": ["*"],
      "output_encoding": "json",
      "backend": [
        {
          "comment": "Backend 0: Obtain consent-scoped M2M token from Keycloak",
          "url_pattern": "/realms/umzh-connect/protocol/openid-connect/token",
          "host": ["{{ env "KEYCLOAK_URL" }}"],
          "encoding": "json",
          "method": "POST",
          "group": "token_exchange",
          "extra_config": {
            "modifier/lua-backend": {
              "sources": ["lua/scoped_token.lua"],
              "pre": "pre_backend(request, '{{ env "CLIENT_ID" }}', '{{ env "CLIENT_SECRET" }}')"
            }
          }
        },
        {
          "comment": "Backend 1: Forward FHIR request to partner external gateway with M2M token",
          "url_pattern": "/fhir/{resource}",
          "host": ["http://{{ env "PARTNER_EXTERNAL_HOST" }}"],
          "encoding": "json",
          "extra_config": {
            "modifier/lua-backend": {
              "sources": ["lua/proxy_inject_token.lua", "lua/proxy_rewrite.lua"],
              "allow_open_libs": true,
              "pre": "inject_token(request)",
              "post": "rewriteUrls()"
            }
          }
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "{{ env "KEYCLOAK_URL" }}/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "roles_key": "realm_roles",
          "roles": ["{{ env "PARTY" }}"]
        },
        "proxy": {
          "sequential": true
        }
      }
    },
    {
      "comment": "=== CATEGORY 3: Proxy API — proxies single partner resource with inline token exchange ===",
      "endpoint": "/proxy/{party}/fhir/{resource}/{id}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept", "X-Consent-Id"],
      "output_encoding": "json",
      "backend": [
        {
          "comment": "Backend 0: Obtain consent-scoped M2M token from Keycloak",
          "url_pattern": "/realms/umzh-connect/protocol/openid-connect/token",
          "host": ["{{ env "KEYCLOAK_URL" }}"],
          "encoding": "json",
          "method": "POST",
          "group": "token_exchange",
          "extra_config": {
            "modifier/lua-backend": {
              "sources": ["lua/scoped_token.lua"],
              "pre": "pre_backend(request, '{{ env "CLIENT_ID" }}', '{{ env "CLIENT_SECRET" }}')"
            }
          }
        },
        {
          "comment": "Backend 1: Forward FHIR request to partner external gateway with M2M token",
          "url_pattern": "/fhir/{resource}/{id}",
          "host": ["http://{{ env "PARTNER_EXTERNAL_HOST" }}"],
          "encoding": "json",
          "extra_config": {
            "modifier/lua-backend": {
              "sources": ["lua/proxy_inject_token.lua", "lua/proxy_rewrite.lua"],
              "allow_open_libs": true,
              "pre": "inject_token(request)",
              "post": "rewriteUrls()"
            }
          }
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "{{ env "KEYCLOAK_URL" }}/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "roles_key": "realm_roles",
          "roles": ["{{ env "PARTY" }}"]
        },
        "proxy": {
          "sequential": true
        }
      }
    },
    {
      "comment": "=== Scoped Token — exchanges X-Consent-Id for a service-account JWT that carries consent:<id> in scope ===",
      "endpoint": "/api/actions/scoped-token",
      "method": "POST",
      "input_headers": ["Authorization", "X-Consent-Id"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/realms/umzh-connect/protocol/openid-connect/token",
          "host": ["{{ env "KEYCLOAK_URL" }}"],
          "encoding": "no-op",
          "method": "POST",
          "extra_config": {
            "modifier/lua-backend": {
              "sources": ["lua/scoped_token.lua"],
              "pre": "pre_backend(request, '{{ env "CLIENT_ID" }}', '{{ env "CLIENT_SECRET" }}')"
            }
          }
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "{{ env "KEYCLOAK_URL" }}/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "roles_key": "realm_roles",
          "roles": ["{{ env "PARTY" }}"]
        }
      }
    },
    {
      "comment": "=== CATEGORY 4: Actions API — Create task at partner's external endpoint ===",
      "endpoint": "/api/actions/create-task",
      "method": "POST",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "json",
      "backend": [
        {
          "comment": "Backend 0: Obtain M2M token from Keycloak",
          "url_pattern": "/realms/umzh-connect/protocol/openid-connect/token",
          "host": ["{{ env "KEYCLOAK_URL" }}"],
          "encoding": "json",
          "method": "POST",
          "group": "token_exchange",
          "extra_config": {
            "modifier/lua-backend": {
              "sources": ["lua/scoped_token.lua"],
              "pre": "pre_backend(request, '{{ env "CLIENT_ID" }}', '{{ env "CLIENT_SECRET" }}')"
            }
          }
        },
        {
          "comment": "Backend 1: POST Task to partner external gateway with M2M token",
          "url_pattern": "/fhir/Task",
          "host": ["http://{{ env "PARTNER_EXTERNAL_HOST" }}"],
          "encoding": "json",
          "extra_config": {
            "modifier/lua-backend": {
              "sources": ["lua/proxy_inject_token.lua", "lua/proxy_rewrite_json.lua"],
              "allow_open_libs": true,
              "pre": "inject_token(request)",
              "post": "rewriteUrlsInJson()"
            }
          }
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "{{ env "KEYCLOAK_URL" }}/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "roles_key": "realm_roles",
          "roles": ["{{ env "PARTY" }}"]
        },
        "proxy": {
          "sequential": true
        }
      }
    },
    {
      "comment": "=== CATEGORY 4: Actions API — Fetch all tasks (local + remote partner external) ===",
      "endpoint": "/api/actions/all-tasks",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "input_query_strings": ["*"],
      "output_encoding": "json",
      "backend": [
        {
          "comment": "Backend 0: Obtain M2M token from Keycloak",
          "url_pattern": "/realms/umzh-connect/protocol/openid-connect/token",
          "host": ["{{ env "KEYCLOAK_URL" }}"],
          "encoding": "json",
          "method": "POST",
          "group": "token_exchange",
          "extra_config": {
            "modifier/lua-backend": {
              "sources": ["lua/scoped_token.lua"],
              "pre": "pre_backend(request, '{{ env "CLIENT_ID" }}', '{{ env "CLIENT_SECRET" }}')"
            }
          }
        },
        {
          "comment": "Backend 1: Fetch local tasks from own partition",
          "url_pattern": "/fhir/{{ env "PARTY" }}/Task",
          "host": ["http://nginx-proxy:{{ env "NGINX_PORT" }}"],
          "encoding": "json",
          "group": "local"
        },
        {
          "comment": "Backend 2: Fetch remote tasks from partner external gateway with M2M token",
          "url_pattern": "/fhir/Task",
          "host": ["http://{{ env "PARTNER_EXTERNAL_HOST" }}"],
          "encoding": "json",
          "group": "remote",
          "extra_config": {
            "modifier/lua-backend": {
              "sources": ["lua/proxy_inject_token.lua", "lua/proxy_rewrite_json.lua"],
              "allow_open_libs": true,
              "pre": "inject_token(request)",
              "post": "rewriteUrlsInJson()"
            }
          }
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "{{ env "KEYCLOAK_URL" }}/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "roles_key": "realm_roles",
          "roles": ["{{ env "PARTY" }}"]
        },
        "proxy": {
          "sequential": true
        },
        "modifier/lua-proxy": {
          "sources": ["lua/strip_token_exchange.lua"],
          "post": "strip_token_exchange(response)"
        }
      }
    },
    {
      "comment": "=== OPA Policy Check ===",
      "endpoint": "/api/policy/check",
      "method": "POST",
      "input_headers": ["Authorization", "Content-Type"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/v1/data/umzh/authz/allow",
          "host": ["http://{{ env "OPA_HOST" }}"],
          "encoding": "no-op"
        }
      ]
    }
  ]
}
