{
  "$schema": "https://www.krakend.io/schema/krakend.json",
  "version": 3,
  "name": "UMZH Connect — {{ env "GATEWAY_NAME" }} API Gateway",
  "port": 8080,
  "timeout": "30s",
  "cache_ttl": "0s",
  "output_encoding": "no-op",
  "extra_config": {
    "router": {
      "return_error_msg": true
    },
    "security/cors": {
      "allow_origins": ["http://localhost:3000", "*"],
      "allow_methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
      "allow_headers": ["Authorization", "Content-Type", "Accept"],
      "expose_headers": ["Content-Length", "Content-Type"],
      "max_age": "12h",
      "allow_credentials": true
    }
  },
  "endpoints": [
    {
      "comment": "=== Consent-enforced search (gateway-built OPA input, mandatory _id) ===",
      "comment2": "Sequential proxy: (1) KrakenD builds OPA input from JWT claims and _id param; (2) HAPI FHIR executes the search. Access denied returns HTTP 500 (KrakenD CE limitation).",
      "endpoint": "/fhir/{resource}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "input_query_strings": ["_id", "_include"],
      "output_encoding": "json",
      "backend": [
        {
          "url_pattern": "/v1/data/umzh/authz?_r={resource}",
          "host": ["http://opa-{{ env "PARTY" }}:8181"],
          "method": "POST",
          "encoding": "json",
          "group": "opa",
          "extra_config": {
            "modifier/lua-backend": {
              "sources": ["lua/opa_gate.lua"],
              "allow_open_libs": true,
              "pre": "pre_opa_gate_search(request, 'http://nginx-proxy:{{ env "NGINX_PORT" }}/fhir/{{ env "PARTY" }}')"
            }
          }
        },
        {
          "url_pattern": "/fhir/{{ env "PARTY" }}/{resource}",
          "host": ["http://nginx-proxy:{{ env "NGINX_PORT" }}"],
          "encoding": "json"
        }
      ],
      "extra_config": {
        "proxy": { "sequential": true },
        "modifier/lua-proxy": {
          "sources": ["lua/opa_gate.lua"],
          "allow_open_libs": true,
          "post": "post_opa_gate(response, request)"
        },
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "{{ env "KEYCLOAK_URL" }}/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["party_id", "x-party-id"],
            ["smart_scopes", "x-smart-scopes"],
            {{ if eq (env "PARTY") "placer" }}["tenant", "x-tenant"],{{ end }}
            ["scope", "x-scope"]
          ]
        }
      }
    },
    {
      "comment": "=== Consent-enforced single-resource read (gateway-built OPA input) ===",
      "comment2": "Sequential proxy: (1) KrakenD builds OPA input from JWT claims and calls OPA; (2) HAPI FHIR serves the resource. Access denied returns HTTP 500 (KrakenD CE limitation — HTTP 403 requires KrakenD Enterprise security/policies).",
      "endpoint": "/fhir/{resource}/{id}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "json",
      "backend": [
        {
          "url_pattern": "/v1/data/umzh/authz?_r={resource}&_i={id}",
          "host": ["http://opa-{{ env "PARTY" }}:8181"],
          "method": "POST",
          "encoding": "json",
          "group": "opa",
          "extra_config": {
            "modifier/lua-backend": {
              "sources": ["lua/opa_gate.lua"],
              "allow_open_libs": true,
              "pre": "pre_opa_gate(request, 'http://nginx-proxy:{{ env "NGINX_PORT" }}/fhir/{{ env "PARTY" }}')"
            }
          }
        },
        {
          "url_pattern": "/fhir/{{ env "PARTY" }}/{resource}/{id}",
          "host": ["http://nginx-proxy:{{ env "NGINX_PORT" }}"],
          "encoding": "json"
        }
      ],
      "extra_config": {
        "proxy": { "sequential": true },
        "modifier/lua-proxy": {
          "sources": ["lua/opa_gate.lua"],
          "allow_open_libs": true,
          "post": "post_opa_gate(response, request)"
        },
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "{{ env "KEYCLOAK_URL" }}/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["party_id", "x-party-id"],
            ["smart_scopes", "x-smart-scopes"],
            {{ if eq (env "PARTY") "placer" }}["tenant", "x-tenant"],{{ end }}
            ["scope", "x-scope"]
          ]
        }
      }
    },
    {
      "comment": "=== External FHIR API — partner creates Task ===",
      "endpoint": "/fhir/Task",
      "method": "POST",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/{{ env "PARTY" }}/Task",
          "host": ["http://nginx-proxy:{{ env "NGINX_PORT" }}"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "{{ env "KEYCLOAK_URL" }}/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["party_id", "x-party-id"],
            ["smart_scopes", "x-smart-scopes"],
            ["scope", "x-scope"]
          ]
        }
      }
    }
    {{ if eq (env "PARTY") "fulfiller" }}
    ,{
      "comment": "=== External FHIR API — partner updates Task status ===",
      "endpoint": "/fhir/Task/{id}",
      "method": "PUT",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/{{ env "PARTY" }}/Task/{id}",
          "host": ["http://nginx-proxy:{{ env "NGINX_PORT" }}"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "{{ env "KEYCLOAK_URL" }}/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["party_id", "x-party-id"],
            ["smart_scopes", "x-smart-scopes"],
            ["scope", "x-scope"]
          ]
        }
      }
    }
    {{ end }}
  ]
}
