          "cache": true
        }
      }
    },
    {
      "comment": "=== CATEGORY 3: Internal Proxy API (Fulfiller proxying to Placer) ===",
      "endpoint": "/proxy/placer/fhir/{resource}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept", "X-Consent-Id"],
