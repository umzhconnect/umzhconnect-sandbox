      "backend": [
        {
          "url_pattern": "/fhir/{resource}/{id}",
          "host": ["http://hapi-fhir:8080"],
          "encoding": "no-op",
          "extra_config": {
            "modifier/martian": {
              "header.Modifier": {
                "scope": ["request"],
