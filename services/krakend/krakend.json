      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true
        }
      }
    },
    {
      "comment": "=== CATEGORY 2: Standard External FHIR API (restricted per CapabilityStatement) ===",
      "endpoint": "/external/placer/fhir/{resource}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept", "X-Consent-Id"],
      "input_query_strings": ["*"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/{resource}",
          "host": ["http://hapi-fhir:8080"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["party_id", "x-party-id"],
            ["smart_scopes", "x-smart-scopes"],
            ["tenant", "x-tenant"]
          ]
        }
      }
    },
    {
      "endpoint": "/external/placer/fhir/{resource}/{id}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept", "X-Consent-Id"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/{resource}/{id}",
          "host": ["http://hapi-fhir:8080"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["party_id", "x-party-id"],
            ["smart_scopes", "x-smart-scopes"],
            ["tenant", "x-tenant"]
          ]
        }
      }
    },
    {
      "endpoint": "/external/fulfiller/fhir/Task",
      "method": "POST",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/Task",
