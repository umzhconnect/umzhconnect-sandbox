{
  "$schema": "https://www.krakend.io/schema/krakend.json",
  "version": 3,
  "name": "UMZH Connect Sandbox API Gateway",
  "port": 8080,
  "timeout": "30s",
  "cache_ttl": "0s",
  "output_encoding": "no-op",
  "extra_config": {
    "router": {
      "return_error_msg": true
    },
    "security/cors": {
      "allow_origins": ["http://localhost:3000", "*"],
      "allow_methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
      "allow_headers": ["Authorization", "Content-Type", "Accept", "X-Tenant", "X-Consent-Id"],
      "expose_headers": ["Content-Length", "Content-Type"],
      "max_age": "12h",
      "allow_credentials": true
    }
  },
  "endpoints": [
    {
      "comment": "=== CATEGORY 1: Standard Internal FHIR API (Placer) ===",
      "endpoint": "/placer/fhir/{resource}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/{resource}",
          "host": ["http://hapi-fhir:8080"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true
        }
      }
    },
    {
      "endpoint": "/placer/fhir/{resource}/{id}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/{resource}/{id}",
          "host": ["http://hapi-fhir:8080"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true
        }
      }
    },
    {
      "endpoint": "/placer/fhir/{resource}",
      "method": "POST",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/{resource}",
          "host": ["http://hapi-fhir:8080"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true
        }
      }
    },
    {
      "endpoint": "/placer/fhir/{resource}/{id}",
      "method": "PUT",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/{resource}/{id}",
          "host": ["http://hapi-fhir:8080"],
          "encoding": "no-op"
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true
        }
      }
    },
    {
      "comment": "=== CATEGORY 1: Standard Internal FHIR API (Fulfiller) ===",
      "endpoint": "/fulfiller/fhir/{resource}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/{resource}",
          "host": ["http://hapi-fhir:8080"],
          "encoding": "no-op",
          "extra_config": {
            "modifier/martian": {
              "header.Modifier": {
                "scope": ["request"],
                "name": "X-Partition-Name",
                "value": "fulfiller"
              }
            }
          }
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true
        }
      }
    },
    {
      "endpoint": "/fulfiller/fhir/{resource}/{id}",
      "method": "GET",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/{resource}/{id}",
          "host": ["http://hapi-fhir:8080"],
          "encoding": "no-op",
          "extra_config": {
            "modifier/martian": {
              "header.Modifier": {
                "scope": ["request"],
                "name": "X-Partition-Name",
                "value": "fulfiller"
              }
            }
          }
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true
        }
      }
    },
    {
      "endpoint": "/fulfiller/fhir/{resource}",
      "method": "POST",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/{resource}",
          "host": ["http://hapi-fhir:8080"],
          "encoding": "no-op",
          "extra_config": {
            "modifier/martian": {
              "header.Modifier": {
                "scope": ["request"],
                "name": "X-Partition-Name",
                "value": "fulfiller"
              }
            }
          }
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/umzh-connect/protocol/openid-connect/certs",
          "issuer": "http://localhost:8180/realms/umzh-connect",
          "disable_jwk_security": true,
          "cache": true
        }
      }
    },
    {
      "endpoint": "/fulfiller/fhir/{resource}/{id}",
      "method": "PUT",
      "input_headers": ["Authorization", "Content-Type", "Accept"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/fhir/{resource}/{id}",
          "host": ["http://hapi-fhir:8080"],
          "encoding": "no-op",
          "extra_config": {
            "modifier/martian": {
              "header.Modifier": {
                "scope": ["request"],
                "name": "X-Partition-Name",
