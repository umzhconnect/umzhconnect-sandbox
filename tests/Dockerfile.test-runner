# Test runner image: the upstream hurl image is Alpine with only wget.
# get-token.sh's L2 (private_key_jwt) flow needs curl to fetch the RSA key
# and openssl to sign the assertion — add both.
FROM ghcr.io/orange-opensource/hurl:6.0.0
USER root
ARG BUILD_INSECURE=
RUN if [ -n "$BUILD_INSECURE" ]; then sed -i 's|https://|http://|g' /etc/apk/repositories; fi \
 && apk add --no-cache curl openssl
