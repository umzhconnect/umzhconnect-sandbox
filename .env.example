# =============================================================================
# UMZH Connect Sandbox - Environment Configuration
#
# Copy this file to .env and adjust values as needed.
# .env is gitignored and will not be committed.
# For production, use deployment/.env.prod.example instead.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=umzh
POSTGRES_PASSWORD=umzh_sandbox_2025
POSTGRES_DB=hapi_fhir

# --- HAPI FHIR ---
HAPI_FHIR_PORT=8090
HAPI_FHIR_BASE_URL=http://hapi-fhir:8080

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8180
PLACER_USER_PASSWORD=placer123
FULFILLER_USER_PASSWORD=fulfiller123
ADMIN_USER_PASSWORD=admin123
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=umzh-connect

# --- Keycloak Clients (Level 1 - shared secret) ---
PLACER_CLIENT_ID=placer-client
PLACER_CLIENT_SECRET=placer-secret-2025
FULFILLER_CLIENT_ID=fulfiller-client
FULFILLER_CLIENT_SECRET=fulfiller-secret-2025

# --- Keycloak Clients (Level 2 - private_key_jwt) ---
PLACER_L2_CLIENT_ID=placer-client-l2
FULFILLER_L2_CLIENT_ID=fulfiller-client-l2
# JWKS endpoints Keycloak fetches to verify L2 private_key_jwt assertions.
# Local: internal Docker address (Keycloak reaches the gateway on umzh-net).
PLACER_JWKS_URL=http://apisix-placer-external:9080/jwks.json
FULFILLER_JWKS_URL=http://apisix-fulfiller-external:9080/jwks.json

# --- APISIX — internal + external gateway per party ---
APISIX_PLACER_PORT=8080
APISIX_PLACER_EXTERNAL_PORT=8081
APISIX_FULFILLER_PORT=8082
APISIX_FULFILLER_EXTERNAL_PORT=8083

# --- OPA — one instance per party ---
OPA_PLACER_PORT=8181
OPA_FULFILLER_PORT=8182

# --- Registry (public Organization directory, no auth) ---
REGISTRY_PORT=8084

# L2 JWKS endpoints are co-located on each party's external APISIX gateway
# (the hospital's public face) at /jwks.json — i.e. http://localhost:8081/jwks.json
# for placer and http://localhost:8083/jwks.json for fulfiller. No separate
# port needed.

# --- Key custodians (one per party — sign assertions + publish JWKS) ---
KEY_CUSTODIAN_PLACER_PORT=8087
KEY_CUSTODIAN_FULFILLER_PORT=8089
# --- Reseed API ---
RESEED_API_PORT=9001

# --- Web App ---
WEB_APP_PORT=3000
# Public origin of the SPA — resolved into Keycloak realm-export.json
# (webOrigins / redirectUris / rootUrl) at import time.
WEB_APP_PUBLIC_URL=http://localhost:3000
VITE_API_BASE_URL=
VITE_KEYCLOAK_REALM=umzh-connect
VITE_KEYCLOAK_CLIENT_ID=web-app

# --- Public URLs (per deployment) ---
# The browser builds gateway URLs from the host you open the app on, so no
# host is hardcoded. Keycloak is the exception: its issuer is part of token
# identity and must be a single canonical URL that the browser AND the API
# gateways agree on. Set both to the host you actually browse to.
KEYCLOAK_PUBLIC_URL=http://localhost:8180
WEB_APP_PUBLIC_URL=http://localhost:3000

# Optional full-URL overrides (normally derived from page host + the *_PORT
# vars). Uncomment only behind a reverse proxy / HTTPS where host:port differs.
# VITE_KEYCLOAK_URL=
# VITE_PLACER_URL=
# VITE_PLACER_EXTERNAL_URL=
# VITE_FULFILLER_URL=
# VITE_FULFILLER_EXTERNAL_URL=
# VITE_REGISTRY_URL=
# VITE_RESEED_API_URL=

# Extra flags for the keycloak-mapper-build Maven step. Optional; leave unset on
# a normal network. Set the insecure securityMode to build behind a TLS-intercepting proxy.
#MAVEN_FLAGS=-Daether.connector.https.securityMode=insecure
