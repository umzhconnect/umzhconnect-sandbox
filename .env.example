# =============================================================================
# UMZH Connect Sandbox - Environment Configuration
#
# Copy this file to .env and adjust values as needed.
# .env is gitignored and will not be committed.
#
# LOCAL DEV: defaults below work out of the box.
# PRODUCTION: set strong secrets and replace all localhost URLs with your
#   public domain (see VITE_* and WEB_APP_PUBLIC_URL at the bottom).
#   The prod overlay (deployment/docker-compose.prod.yml) reads these values
#   directly — no hardcoded URLs in that file.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=umzh
POSTGRES_PASSWORD=umzh_sandbox_2025
POSTGRES_DB=hapi_fhir

# --- HAPI FHIR ---
HAPI_FHIR_PORT=8090
HAPI_FHIR_BASE_URL=http://hapi-fhir:8080

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8180
PLACER_USER_PASSWORD=placer123
FULFILLER_USER_PASSWORD=fulfiller123
ADMIN_USER_PASSWORD=admin123
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=umzh-connect

# --- Keycloak Clients (Level 1 - shared secret) ---
PLACER_CLIENT_ID=placer-client
PLACER_CLIENT_SECRET=placer-secret-2025
FULFILLER_CLIENT_ID=fulfiller-client
FULFILLER_CLIENT_SECRET=fulfiller-secret-2025

# --- Keycloak Clients (Level 2 - private_key_jwt) ---
PLACER_L2_CLIENT_ID=placer-client-l2
FULFILLER_L2_CLIENT_ID=fulfiller-client-l2
# JWKS endpoints Keycloak fetches to verify L2 private_key_jwt assertions.
# Local: internal Docker address (Keycloak reaches the gateway on umzh-net).
PLACER_JWKS_URL=http://apisix-placer-external:9080/jwks.json
FULFILLER_JWKS_URL=http://apisix-fulfiller-external:9080/jwks.json

# --- APISIX — internal + external gateway per party ---
APISIX_PLACER_PORT=8080
APISIX_PLACER_EXTERNAL_PORT=8081
APISIX_FULFILLER_PORT=8082
APISIX_FULFILLER_EXTERNAL_PORT=8083

# --- OPA — one instance per party ---
OPA_PLACER_PORT=8181
OPA_FULFILLER_PORT=8182

# --- Registry (public Organization directory, no auth) ---
REGISTRY_PORT=8084
# Canonical public registry base URL — the single source of truth. The web-app
# (VITE_REGISTRY_URL), admin-api/seed (REGISTRY_EXTERNAL_URL), nginx-proxy, and
# each M2M client's organization_reference claim all derive from this value in
# docker-compose. It MUST match the URL used in stored consent actors and
# Task.requester so OPA consent matching and Task requester-inject work.
# Deployed: set to the public registry subdomain, e.g.
#   REGISTRY_PUBLIC_URL=https://registry.sandbox.umzh-connect.ch
REGISTRY_PUBLIC_URL=http://localhost:8084

# L2 JWKS endpoints are co-located on each party's external APISIX gateway
# (the hospital's public face) at /jwks.json — i.e. http://localhost:8081/jwks.json
# for placer and http://localhost:8083/jwks.json for fulfiller. No separate
# port needed.

# --- Key custodians (one per party — sign assertions + publish JWKS) ---
KEY_CUSTODIAN_PLACER_PORT=8087
KEY_CUSTODIAN_FULFILLER_PORT=8089

# --- Admin API (merged reseed + onboarding) ---
ADMIN_API_PORT=9000
# Keycloak client used by admin-api for admin tokens + token introspection.
ONBOARDING_CLIENT_SECRET=onboarding-secret-2025
VITE_ADMIN_API_URL=http://localhost:9000

# --- Web App ---
WEB_APP_PORT=3000
# Public origin of the SPA — resolved into Keycloak realm-export.json
# (webOrigins / redirectUris / rootUrl) at import time.
# Production: set to https://sandbox.umzh-connect.ch
WEB_APP_PUBLIC_URL=http://localhost:3000
VITE_API_BASE_URL=
# Public URLs for the SPA and nginx self-link rewriter.
# Production: replace localhost with your public subdomains, e.g.:
#   VITE_KEYCLOAK_URL=https://auth.sandbox.umzh-connect.ch
#   VITE_PLACER_URL=https://placer-int.sandbox.umzh-connect.ch
#   VITE_PLACER_EXTERNAL_URL=https://placer.sandbox.umzh-connect.ch
#   VITE_FULFILLER_URL=https://fulfiller-int.sandbox.umzh-connect.ch
#   VITE_FULFILLER_EXTERNAL_URL=https://fulfiller.sandbox.umzh-connect.ch
#   REGISTRY_PUBLIC_URL=https://registry.sandbox.umzh-connect.ch  (see Registry section above)
#   VITE_ADMIN_API_URL=https://admin.sandbox.umzh-connect.ch
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=umzh-connect
VITE_KEYCLOAK_CLIENT_ID=web-app
VITE_PLACER_URL=http://localhost:8080
VITE_PLACER_EXTERNAL_URL=http://localhost:8081
VITE_FULFILLER_URL=http://localhost:8082
VITE_FULFILLER_EXTERNAL_URL=http://localhost:8083

# Extra flags for the keycloak-mapper-build Maven step. Optional; leave unset on
# a normal network. Set the insecure securityMode to build behind a TLS-intercepting proxy.
#MAVEN_FLAGS=-Daether.connector.https.securityMode=insecure
