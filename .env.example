# =============================================================================
# UMZH-Connect COW Sandbox — Environment Variables
# Copy to .env and fill in secrets before running.
# =============================================================================

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_DB_PASSWORD=keycloakpass
KC_HOSTNAME=localhost
KC_PORT=8180

# ── HAPI FHIR ─────────────────────────────────────────────────────────────────
HAPI_DB_PASSWORD=hapipass
HAPI_PORT=8282

# ── KrakenD ───────────────────────────────────────────────────────────────────
KRAKEND_PORT_A=8484
KRAKEND_PORT_B=8485

# ── OPA ───────────────────────────────────────────────────────────────────────
OPA_PORT_A=8181
OPA_PORT_B=8182

# ── Backend (FastAPI) ─────────────────────────────────────────────────────────
BACKEND_PORT=8000
# Internal service URLs (used by backend container)
KEYCLOAK_URL=http://keycloak:8080
HAPI_FHIR_URL=http://hapi-fhir:8080
KRAKEND_A_URL=http://krakend-a:8080
KRAKEND_B_URL=http://krakend-b:8080
OPA_A_URL=http://opa-a:8181
OPA_B_URL=http://opa-b:8182
KEYCLOAK_REALM=umzh-sandbox

# ── Client Credentials (Level 1 — client_secret_basic) ───────────────────────
PLACER_CLIENT_ID=placer-client
PLACER_CLIENT_SECRET=placer-secret-change-me
FULFILLER_CLIENT_ID=fulfiller-client
FULFILLER_CLIENT_SECRET=fulfiller-secret-change-me
BACKEND_CLIENT_ID=backend-client
BACKEND_CLIENT_SECRET=backend-secret-change-me

# ── Security Level ─────────────────────────────────────────────────────────────
# AUTH_LEVEL=1  => client_secret_basic (default, sandbox)
# AUTH_LEVEL=2  => private_key_jwt (production)
# AUTH_LEVEL=3  => mTLS (high-risk)
AUTH_LEVEL=1

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=umzh-sandbox
VITE_KEYCLOAK_CLIENT_ID=frontend-client
VITE_BACKEND_URL=http://localhost:8000
